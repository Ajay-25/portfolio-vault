# ──────────────────────────────────────────
# VAULTED — Environment Variables
# Copy this file to .env.local and fill in.
# ──────────────────────────────────────────

# ── Auth ──────────────────────────────────
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Must match: NEXTAUTH_URL/api/auth/callback/google in Google Console
AUTH_SECRET=generate-with-npx-auth-secret
NEXTAUTH_URL=http://localhost:3000

# Only this email can log in (comma-separated for multiple)
ALLOWED_EMAIL=you@gmail.com

# ── Database (Neon) ───────────────────────
# Get from: https://console.neon.tech → your project → Connection string
# Use the "Pooled" connection string for DATABASE_URL
DATABASE_URL=postgresql://user:password@pooled.neon.tech/dbname?sslmode=require

# Use the "Direct" connection for migrations (no pooler)
DIRECT_URL=postgresql://user:password@direct.neon.tech/dbname?sslmode=require

# ── CAS Import ────────────────────────────
# Parse CAS locally with casparser CLI, then import JSON in Settings.
#   pip install casparser
#   casparser ~/Downloads/cas.pdf -p YOUR_PAN -o parsed.json
# Upload parsed.json via Settings → Import JSON.
# Alternatively, use Settings → Import CSV with schemeCode, schemeName, units, avgNAV columns.

# ── Cron Security ─────────────────────────
# Any random secret string. Vercel cron jobs send this to authenticate.
CRON_SECRET=generate-any-random-string

# ── Web Push (optional — for price alerts) ──
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:you@gmail.com
